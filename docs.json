{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Spoo.me Docs",
  "colors": {
    "primary": "#A855F7",
    "light": "#C084FC",
    "dark": "#7C3AED"
  },
  "favicon": "/images/logo/logo.png",
  "navigation": {
    "tabs": [
      {
        "tab": "spoo.me",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "api-keys",
              "rate-limits"
            ]
          },
          {
            "group": "API v1 Reference",
            "openapi": "openapi-v1.json",
            "pages": [
              {
                "group": "URL Shortening",
                "icon": "link",
                "pages": [
                  "POST /api/v1/shorten"
                ]
              },
              {
                "group": "Link Management",
                "icon": "list-check",
                "pages": [
                  "GET /api/v1/urls",
                  "PATCH /api/v1/urls/{url_id}",
                  "PATCH /api/v1/urls/{url_id}/status",
                  "DELETE /api/v1/urls/{url_id}"
                ]
              },
              {
                "group": "Statistics",
                "icon": "chart-line",
                "pages": [
                  "GET /api/v1/stats",
                  "GET /api/v1/export"
                ]
              }
            ]
          },
          {
            "group": "API v0 Reference (Legacy)",
            "openapi": "openapi-v0.json",
            "pages": [
              {
                "group": "URL Shortening",
                "icon": "unlink",
                "pages": [
                  "api-reference/shorten-url",
                  "POST /emoji"
                ]
              },
              {
                "group": "Analytics",
                "icon": "chart-spline",
                "pages": [
                  "POST /stats/{shortCode}"
                ]
              },
              {
                "group": "Data Export",
                "icon": "file-down",
                "pages": [
                  "POST /export/{shortCode}/{exportFormat}"
                ]
              }
            ]
          },
          {
            "group": "Tools & Libraries",
            "pages": [
              "tools/python-library",
              "tools/github-action",
              "tools/spoobot"
            ]
          },
          {
            "group": "Self Hosting",
            "pages": [
              "self-hosting/introduction",
              "self-hosting/setting-up-mongo",
              "self-hosting/setting-up-redis",
              "self-hosting/setting-up-authentication",
              "self-hosting/creating-discord-webhooks",
              {
                "group": "Deployment",
                "icon": "server",
                "pages": [
                  "self-hosting/cloud-deployment",
                  "self-hosting/docker-deployment",
                  "self-hosting/local-development"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "spoo-qr",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "qr/introduction"
            ]
          },
          {
            "group": "API Reference",
            "openapi": "openapi-qr.json",
            "pages": [
              {
                "group": "Classic",
                "icon": "scan",
                "pages": [
                  "GET /api/v1/classic",
                  "POST /api/v1/classic"
                ]
              },
              {
                "group": "Gradient",
                "icon": "palette",
                "pages": [
                  "GET /api/v1/gradient",
                  "POST /api/v1/gradient"
                ]
              },
              {
                "group": "Batch",
                "icon": "layers",
                "pages": [
                  "POST /api/v1/batch"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logo/logo-full-light.png",
    "dark": "/images/logo/logo-full-dark.png",
    "href": "https://spoo.me"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "label": "Community",
        "href": "https://spoo.me/discord"
      },
      {
        "label": "Support",
        "href": "https://spoo.me/contact"
      }
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://spoo.me/discord",
      "github": "https://spoo.me/github",
      "twitter": "https://x.com/spoo_me",
      "instagram": "https://www.instagram.com/spoo.me",
      "linkedin": "https://www.linkedin.com/company/spoo-me",
      "youtube": "https://www.youtube.com/@spoo-me"
    }
  },
  "topbar": {
    "style": "gradient"
  }
}
