        "tags": [
          "QR Code Generation"
        ],
        "summary": "Classic QR",
        "description": "Generate a QR code with solid fill and background colors.",
        "operationId": "generate_classic_get_api_v1_classic_get",
        "parameters": [
          {
            "name": "content",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Text or URL to encode",
              "title": "Content"
            },
            "description": "Text or URL to encode"
          },
          {
            "name": "color",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Fill color (hex, name, or RGB)",
              "default": "black",
              "title": "Color"
            },
            "description": "Fill color (hex, name, or RGB)"
          },
          {
            "name": "background",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Background color",
              "default": "white",
              "title": "Background"
            },
            "description": "Background color"
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 1000,
                  "minimum": 10
